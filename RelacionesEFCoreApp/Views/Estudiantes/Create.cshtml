@model RelacionesEFCoreApp.Models.Inscripcion

<h2 class="text-primary">Inscribir Estudiante a Curso</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <div class="card bg-dark border-light">
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group mb-3">
                        <label asp-for="EstudianteId" class="control-label text-light">Estudiante</label>
                        <select asp-for="EstudianteId" class="form-select" asp-items="ViewBag.EstudianteId"></select>
                    </div>
                    
                    <div class="form-group mb-3">
                        <label asp-for="CursoId" class="control-label text-light">Curso</label>
                        <select asp-for="CursoId" class="form-select" asp-items="ViewBag.CursoId"></select>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="FechaInscripcion" class="control-label text-light"></label>
                        <input asp-for="FechaInscripcion" type="date" class="form-control" />
                        <span asp-validation-for="FechaInscripcion" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Estado" class="control-label text-light"></label>
                        <select asp-for="Estado" class="form-select">
                            <option value="Activo">Activo</option>
                            <option value="Aprobado">Aprobado</option>
                            <option value="Reprobado">Reprobado</option>
                        </select>
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <input type="submit" value="Guardar Inscripción" class="btn btn-primary w-100" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>